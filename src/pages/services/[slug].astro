---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;

import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
---

<BaseLayout title={`${service.title} | Services`} description={service.excerpt}>
  <article class="detail">
    <p><a href="/services">← Back to Services</a></p>
    <p class="eyebrow">Service</p>
    <h1>{service.title}</h1>
    <p>{service.content.intro}</p>

    <section class="surface-box">
      <h2>Was ist drin</h2>
      <ul>
        {service.deliverables.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="surface-box">
      <h2>Ablauf</h2>
      <ol>
        {service.content.process.map((step: string) => (
          <li>{step}</li>
        ))}
      </ol>
    </section>

    <section class="surface-box cta-box">
      <h2>Nächster Schritt</h2>
      <p>{service.content.cta}</p>
      <a class="button" href="mailto:hello@yannicksalm.ch">Jetzt Kontakt aufnehmen</a>
    </section>
  </article>
</BaseLayout>