---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Kontakt | Yannick Salm"
    description="Kontakt zu Yannick Salm."
>
    <section class="contact_section container">
        <div class="contact_wrapper">
            <div class="contact_intro">
                <h2 class="contact_title">Kontakt</h2>
                <p class="contact_text">
                    Hast du ein Projekt im Kopf oder möchtest einfach Hallo sagen?
                    Sende mir eine Nachricht und ich melde mich bei dir.
                </p>
            </div>

            <form
                id="contactForm"
                class="contact_form"
                action="https://formspree.io/f/mreybznj"
                method="POST"
            >
                <div class="contact_row">
                    <div class="contact_field">
                        <label class="contact_label" for="name">Name</label>
                        <input
                            id="name"
                            name="name"
                            type="text"
                            class="contact_input"
                            placeholder="Dein Name"
                            required
                            autocomplete="name"
                        />
                    </div>

                    <div class="contact_field">
                        <label class="contact_label" for="email">E-Mail</label>
                        <input
                            id="email"
                            name="email"
                            type="email"
                            class="contact_input"
                            placeholder="deine@email.ch"
                            required
                            autocomplete="email"
                        />
                    </div>
                </div>

                <div class="contact_field">
                    <label class="contact_label" for="subject">Betreff</label>
                    <input
                        id="subject"
                        name="subject"
                        type="text"
                        class="contact_input"
                        placeholder="Betreff"
                        required
                    />
                </div>

                <div class="contact_field">
                    <label class="contact_label" for="message">Nachricht</label>
                    <textarea
                        id="message"
                        name="message"
                        class="contact_textarea"
                        rows="6"
                        placeholder="Deine Nachricht"
                        required></textarea>
                </div>

                <button type="submit" class="contact_button">
                    Nachricht senden
                </button>
            </form>
        </div>
    </section>

    <div id="contactSuccessModal" class="contact_modal">
        <div class="contact_modal-content">
            <h3>Nachricht erfolgreich gesendet</h3>
            <p>
                Vielen Dank für deine Nachricht. Ich werde mich so schnell wie
                möglich bei dir melden.
            </p>
            <button
                type="button"
                class="contact_modal-close"
                id="contactModalClose"
            >
                Schliessen
            </button>
        </div>
    </div>

    <script is:inline src="/scripts/contact-form.js"></script>
</BaseLayout>