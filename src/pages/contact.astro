---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Contact | Yannick Salm"
    description="Kontakt zu Yannick Salm."
>
    <section class="contact_section container">
        <div class="contact_wrapper">
            <div class="contact_intro">
                <h2 class="contact_title">Contact</h2>
                <p class="contact_text">
                    Have a project in mind or just want to say hello? Send a
                    message and I will get back to you.
                </p>
            </div>

            <form class="contact_form">
                <div class="contact_row">
                    <div class="contact_field">
                        <label class="contact_label">Name</label>
                        <input
                            type="text"
                            class="contact_input"
                            placeholder="Your name"
                        />
                    </div>

                    <div class="contact_field">
                        <label class="contact_label">Email</label>
                        <input
                            type="email"
                            class="contact_input"
                            placeholder="you@email.com"
                        />
                    </div>
                </div>

                <div class="contact_field">
                    <label class="contact_label">Subject</label>
                    <input
                        type="text"
                        class="contact_input"
                        placeholder="Subject"
                    />
                </div>

                <div class="contact_field">
                    <label class="contact_label">Message</label>
                    <textarea
                        class="contact_textarea"
                        rows="6"
                        placeholder="Your message"></textarea>
                </div>

                <button class="contact_button"> Send Message </button>
            </form>
        </div>
    </section>
</BaseLayout>
