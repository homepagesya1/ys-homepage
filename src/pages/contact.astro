---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Yannick Salm"
  description="Kontakt zu Yannick Salm."
>
  <section class="contact_section container">
    <div class="contact_wrapper">
      <div class="contact_intro">
        <h2 class="contact_title">Contact</h2>
        <p class="contact_text">
          Have a project in mind or just want to say hello? Send a
          message and I will get back to you.
        </p>
      </div>

      <form
        id="contactForm"
        class="contact_form"
        action="https://formspree.io/f/mreybznj"
        method="POST"
      >
        <div class="contact_row">
          <div class="contact_field">
            <label class="contact_label" for="name">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              class="contact_input"
              placeholder="Your name"
              required
              autocomplete="name"
            />
          </div>

          <div class="contact_field">
            <label class="contact_label" for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              class="contact_input"
              placeholder="you@email.com"
              required
              autocomplete="email"
            />
          </div>
        </div>

        <div class="contact_field">
          <label class="contact_label" for="subject">Subject</label>
          <input
            id="subject"
            name="subject"
            type="text"
            class="contact_input"
            placeholder="Subject"
            required
          />
        </div>

        <div class="contact_field">
          <label class="contact_label" for="message">Message</label>
          <textarea
            id="message"
            name="message"
            class="contact_textarea"
            rows="6"
            placeholder="Your message"
            required
          ></textarea>
        </div>

        <button type="submit" class="contact_button">
          Send Message
        </button>
      </form>
    </div>
  </section>

  <div id="contactSuccessModal" class="contact_modal">
    <div class="contact_modal-content">
      <h3>Message sent successfully</h3>
      <p>
        Thank you for your message. I will get back to you as soon as possible.
      </p>
      <button type="button" class="contact_modal-close" onclick="closeContactPopup()">
        Close
      </button>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById("contactForm");

    function showContactPopup() {
      const modal = document.getElementById("contactSuccessModal");
      if (modal) modal.classList.add("active");
    }

    window.closeContactPopup = function () {
      const modal = document.getElementById("contactSuccessModal");
      if (modal) modal.classList.remove("active");
    };

    async function sendContactForm() {
      const endpoint = form.action;

      const nameValue = document.getElementById("name")?.value.trim() || "";
      const emailValue = document.getElementById("email")?.value.trim() || "";
      const subjectValue = document.getElementById("subject")?.value.trim() || "";
      const messageValue = document.getElementById("message")?.value.trim() || "";

      const formattedMessage =
`Name:
- ${nameValue}

Email:
- ${emailValue}

Subject:
- ${subjectValue}

Message:
${messageValue}`;

      const fd = new FormData();
      fd.append("name", nameValue);
      fd.append("email", emailValue);
      fd.append("subject", subjectValue);
      fd.append("message", formattedMessage);
      fd.append("_subject", `New contact message: ${subjectValue}`);

      const res = await fetch(endpoint, {
        method: "POST",
        body: fd,
        headers: { Accept: "application/json" }
      });

      if (!res.ok) {
        let text = "An error occurred while sending the message. Please try again.";
        try {
          const data = await res.json();
          if (data?.errors?.length) {
            text = data.errors.map((e) => e.message).join("\\n");
          }
        } catch (_) {}
        throw new Error(text);
      }
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const btn = form.querySelector('button[type="submit"]');
      const oldText = btn ? btn.textContent : "";

      try {
        if (btn) {
          btn.disabled = true;
          btn.textContent = "Sending ...";
        }

        await sendContactForm();
        form.reset();
        showContactPopup();
      } catch (err) {
        alert(err.message || "An error occurred while sending the message.");
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.textContent = oldText || "Send Message";
        }
      }
    });
  </script>
</BaseLayout>