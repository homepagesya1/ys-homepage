---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { projects } from "../data/projects";
import { services } from "../data/services";

const latestProjects = [...projects]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

const topServices = [...services]
  .sort((a, b) => b.popularity - a.popularity)
  .slice(0, 3);

const skills = ["UI / UX", "Webseiten", "Handwerk", "System Engineering"];

const socials = [
  {
    name: "GitHub",
    url: "https://github.com/Sky-Walker-xlsr",
    icon: "/icons/github.png",
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/yannick-salm-057945361/",
    icon: "/icons/linkedin.png",
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/sky_gogggles/",
    icon: "/icons/instagram.png",
  },
];
---

<BaseLayout
  title="Home | Yannick Salm"
  description="Portfolio Startseite von Yannick Salm."
>
  <section class="hero">
    <div>
      <p class="eyebrow">Portfolio</p>
      <h1>Yannick Salm</h1>
      <p>
        Ich bin Yannick, angehender Informatiker mit Leidenschaft für Design und
        saubere Lösungen. Struktur, Performance und Disziplin prägen meine
        Arbeit – im Projekt wie im Sport.
      </p>
      <div class="socials">
        {
          socials.map((social) => (
            <a href={social.url} target="_blank" rel="noopener noreferrer">
              <img src={social.icon} alt={social.name} />
              <span>{social.name}</span>
            </a>
          ))
        }
      </div>
    </div>
    <div class="profile-frame">
      <img src="/images/Me.png" alt="Portrait von Yannick Salm" />
    </div>
  </section>

  <section>
    <h2>Fähigkeiten</h2>
    <p>
      Meine Fähigkeiten verbinden Gestaltung, technische Umsetzung und
      praktisches Denken. Von der Konzeption digitaler Lösungen über die
      Entwicklung von Websites bis hin zu systemtechnischen Grundlagen arbeite
      ich strukturiert und lösungsorientiert.
    </p>
    <ul class="chip-list" aria-label="Skills">
      {skills.map((skill) => <li>{skill}</li>)}
    </ul>
  </section>

  <section>
    <div class="section-head">
      <h2>Neueste Projekte</h2>
      <a href="/projects">Alle Projekte ansehen</a>
    </div>
    <div class="card-grid-home">
      {latestProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Services</h2>
      <a href="/services">Alle Services ansehen</a>
    </div>
    <br />
    <div class="card-grid">
      {topServices.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>
</BaseLayout>
