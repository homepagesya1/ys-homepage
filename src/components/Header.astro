---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projekte' },
  { href: '/services', label: 'Services' }
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">YS.</a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">
      ☰
      <span class="sr-only">Menü öffnen</span>
    </button>

    <nav class="desktop-nav" aria-label="Hauptnavigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a class={currentPath === item.href ? 'active' : ''} href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="theme-toggle" type="button" aria-label="Zwischen Light und Dark Mode wechseln">
      Theme: Dark
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile Navigation" hidden>
    <ul class="container">
      {navItems.map((item) => (
        <li>
          <a class={currentPath === item.href ? 'active' : ''} href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const root = document.documentElement;
  const storageKey = 'theme-preference';

  /** @param {'dark' | 'light'} theme */
  const applyTheme = (theme) => {
    root.setAttribute('data-theme', theme);
    localStorage.setItem(storageKey, theme);

    document.querySelectorAll('.theme-toggle').forEach((button) => {
      button.textContent = `Theme: ${theme === 'dark' ? 'Dark' : 'Light'}`;
    });
  };

  const savedTheme = localStorage.getItem(storageKey);
  applyTheme(savedTheme === 'light' ? 'light' : 'dark');

  document.querySelectorAll('.theme-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const nextTheme = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      applyTheme(nextTheme);
    });
  });

  const menuToggle = document.querySelector('.menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  if (menuToggle && mobileNav) {
    menuToggle.addEventListener('click', () => {
      const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!expanded));
      mobileNav.hidden = expanded;
    });
  }
</script>